{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 5173
    },
    {
      "name": "ui-preview-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "tools/ui-preview", "-p", "8766", "--no-dotfiles", "-c-1"],
      "port": 8766
    },
    {
      "name": "watch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["build.js", "--watch"],
      "port": 0
    },
    {
      "name": "test:watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vitest"],
      "port": 0
    },
    {
      "name": "dev-bridge",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "tools/dev-bridge/server.ts"],
      "port": 3456,
      "autoPort": true
    }
  ]
}
