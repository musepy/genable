{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": {},
      "enabled": true
    },
    "figma-dev-mode-mcp-server": {
      "type": "local",
      "command": ["npx", "mcp-remote", "http://127.0.0.1:3845/sse"],
      "env": {},
      "enabled": true
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-77a889ef-985e-441e-8044-4e5c2dc7376d"
      },
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "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"
      },
      "enabled": true
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "0d87c5f9-c169-4d72-acdb-8036a2def5b0"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "env": {},
      "enabled": true
    }
  }
}
