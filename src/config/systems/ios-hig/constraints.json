{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "iOS Human Interface Guidelines semantic constraints",
  "constraints": {
    "BUTTON": {
      "hMin": 28,
      "hMax": 56,
      "hDefault": 44,
      "wMin": 64,
      "paddingHorizontal": 20,
      "gapDefault": 8,
      "layoutSizingHorizontal": "HUG",
      "layoutSizingVertical": "FIXED",
      "cornerRadius": 12,
      "priority": 8,
      "variants": {
        "mini": { "height": 28 },
        "small": { "height": 32 },
        "regular": { "height": 44 },
        "large": { "height": 50 }
      }
    },
    "ICON_BUTTON": {
      "hMin": 28,
      "hMax": 56,
      "hDefault": 44,
      "aspectRatio": 1,
      "layoutSizingVertical": "FIXED",
      "priority": 8
    },
    "TEXT_FIELD": {
      "hMin": 36,
      "hMax": 56,
      "hDefault": 44,
      "wMin": 120,
      "wDefault": 300,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "FIXED",
      "cornerRadius": 10,
      "priority": 7
    },
    "TEXT_AREA": {
      "hMin": 80,
      "hDefault": 120,
      "wMin": 200,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 7
    },
    "SEARCH_BAR": {
      "hMin": 36,
      "hMax": 56,
      "hDefault": 44,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "FIXED",
      "priority": 7
    },
    "AVATAR": {
      "wMin": 28,
      "wMax": 96,
      "wDefault": 44,
      "aspectRatio": 1,
      "cornerRadius": 999,
      "layoutSizingHorizontal": "FIXED",
      "layoutSizingVertical": "FIXED",
      "priority": 6
    },
    "DIVIDER": {
      "hFixed": 0.5,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "FIXED",
      "priority": 10
    },
    "CARD": {
      "paddingMin": 20,
      "cornerRadius": 10,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 4
    },
    "SECTION": {
      "paddingMin": 16,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 3
    },
    "NAV_BAR": {
      "hMin": 44,
      "hMax": 96,
      "hDefault": 44,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 6
    },
    "TAB_BAR": {
      "hMin": 32,
      "hMax": 56,
      "hDefault": 49,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "FIXED",
      "priority": 7
    },
    "ACTION_BAR": {
      "hMin": 44,
      "hMax": 80,
      "hDefault": 49,
      "paddingMin": 16,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 7
    },
    "MODAL": {
      "paddingMin": 20,
      "cornerRadius": 14,
      "layoutSizingVertical": "HUG",
      "priority": 8
    },
    "DATA_TABLE": {
      "paddingMin": 0,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "gapDefault": 0,
      "priority": 5
    },
    "BADGE": {
      "hMin": 18,
      "hMax": 28,
      "layoutSizingHorizontal": "HUG",
      "layoutSizingVertical": "FIXED",
      "cornerRadius": 999,
      "priority": 7
    },
    "DEFAULT": {
      "layoutSizingHorizontal": "HUG",
      "layoutSizingVertical": "HUG",
      "priority": 0
    }
  }
}
