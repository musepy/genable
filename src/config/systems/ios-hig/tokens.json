{
  "$schema": "https://design-tokens.org/draft-schema",
  "name": "iOS Human Interface Guidelines",
  "version": "1.0.0",
  "description": "Apple iOS Human Interface Guidelines token definitions",

  "components": {
    "BUTTON": {
      "mini": { "height": 28, "paddingH": 10, "radius": 6, "fontSize": 13 },
      "small": { "height": 32, "paddingH": 12, "radius": 8, "fontSize": 15 },
      "regular": { "height": 44, "paddingH": 16, "radius": 10, "fontSize": 17 },
      "large": { "height": 50, "paddingH": 20, "radius": 12, "fontSize": 17 }
    },
    "ICON_BUTTON": {
      "small": { "height": 28, "width": 28, "radius": 6 },
      "regular": { "height": 44, "width": 44, "radius": 10 },
      "large": { "height": 50, "width": 50, "radius": 12 }
    },
    "TEXT_FIELD": {
      "compact": { "height": 36, "paddingH": 12, "radius": 8 },
      "regular": { "height": 44, "paddingH": 16, "radius": 10 }
    },
    "CARD": {
      "grouped": { "radius": 10, "padding": 16 },
      "inset": { "radius": 10, "padding": 20 },
      "plain": { "radius": 0, "padding": 16 }
    },
    "AVATAR": {
      "small": { "height": 28, "width": 28, "radius": 14 },
      "medium": { "height": 44, "width": 44, "radius": 22 },
      "large": { "height": 60, "width": 60, "radius": 30 }
    },
    "DIVIDER": {
      "standard": { "height": 0.5 },
      "inset": { "height": 0.5, "marginLeft": 20 }
    },
    "NAV_BAR": {
      "standard": { "height": 44 },
      "large": { "height": 96 }
    },
    "TAB_BAR": {
      "standard": { "height": 49 },
      "compact": { "height": 32 }
    }
  },

  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 20,
    "xl": 24
  },

  "radius": {
    "none": 0,
    "xs": 4,
    "sm": 6,
    "md": 10,
    "lg": 14,
    "xl": 20,
    "continuous": 9999
  },

  "typography": {
    "largeTitle": { "fontSize": 34, "lineHeight": 41, "fontWeight": 700 },
    "title1": { "fontSize": 28, "lineHeight": 34, "fontWeight": 700 },
    "title2": { "fontSize": 22, "lineHeight": 28, "fontWeight": 700 },
    "title3": { "fontSize": 20, "lineHeight": 25, "fontWeight": 600 },
    "headline": { "fontSize": 17, "lineHeight": 22, "fontWeight": 600 },
    "body": { "fontSize": 17, "lineHeight": 22, "fontWeight": 400 },
    "callout": { "fontSize": 16, "lineHeight": 21, "fontWeight": 400 },
    "subheadline": { "fontSize": 15, "lineHeight": 20, "fontWeight": 400 },
    "footnote": { "fontSize": 13, "lineHeight": 18, "fontWeight": 400 },
    "caption1": { "fontSize": 12, "lineHeight": 16, "fontWeight": 400 },
    "caption2": { "fontSize": 11, "lineHeight": 13, "fontWeight": 400 }
  },

  "cornerSmoothing": 0.6,

  "colorRoles": {
    "text.primary": "label",
    "text.secondary": "secondaryLabel",
    "text.disabled": "tertiaryLabel",
    "text.inverse": "white",
    "surface.default": "systemBackground",
    "surface.muted": "secondarySystemBackground",
    "surface.card": "secondarySystemGroupedBackground",
    "action.primary": "systemBlue",
    "action.destructive": "systemRed",
    "action.accent": "systemBlue"
  }
}
