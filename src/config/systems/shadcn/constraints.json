{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "shadcn/ui semantic constraints",
  "constraints": {
    "BUTTON": {
      "hMin": 24,
      "hMax": 56,
      "hDefault": 40,
      "wMin": 64,
      "paddingHorizontal": 16,
      "gapDefault": 8,
      "layoutSizingHorizontal": "HUG",
      "layoutSizingVertical": "FIXED",
      "cornerRadius": 6,
      "priority": 8,
      "variants": {
        "sm": { "height": 36 },
        "default": { "height": 40 },
        "lg": { "height": 44 }
      }
    },
    "ICON_BUTTON": {
      "hMin": 24,
      "hMax": 56,
      "hDefault": 40,
      "aspectRatio": 1,
      "layoutSizingVertical": "FIXED",
      "priority": 8
    },
    "TEXT_FIELD": {
      "hMin": 32,
      "hMax": 56,
      "hDefault": 40,
      "wMin": 120,
      "wDefault": 280,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "FIXED",
      "cornerRadius": 6,
      "priority": 7
    },
    "TEXT_AREA": {
      "hMin": 80,
      "hDefault": 100,
      "wMin": 200,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 7
    },
    "SEARCH_BAR": {
      "hMin": 32,
      "hMax": 56,
      "hDefault": 40,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "FIXED",
      "priority": 7
    },
    "AVATAR": {
      "wMin": 24,
      "wMax": 96,
      "wDefault": 40,
      "aspectRatio": 1,
      "cornerRadius": 999,
      "layoutSizingHorizontal": "FIXED",
      "layoutSizingVertical": "FIXED",
      "priority": 6
    },
    "DIVIDER": {
      "hFixed": 1,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "FIXED",
      "priority": 10
    },
    "CARD": {
      "paddingMin": 24,
      "cornerRadius": 12,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 4
    },
    "SECTION": {
      "paddingMin": 24,
      "gapDefault": 16,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 3
    },
    "NAV_BAR": {
      "hMin": 40,
      "hMax": 80,
      "hDefault": 56,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 6
    },
    "ACTION_BAR": {
      "hMin": 40,
      "hMax": 80,
      "hDefault": 56,
      "paddingMin": 16,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "priority": 7
    },
    "MODAL": {
      "paddingMin": 24,
      "cornerRadius": 12,
      "layoutSizingVertical": "HUG",
      "priority": 8
    },
    "DATA_TABLE": {
      "paddingMin": 0,
      "layoutSizingHorizontal": "FILL",
      "layoutSizingVertical": "HUG",
      "gapDefault": 0,
      "priority": 5
    },
    "BADGE": {
      "hMin": 18,
      "hMax": 28,
      "hDefault": 22,
      "layoutSizingHorizontal": "HUG",
      "layoutSizingVertical": "FIXED",
      "cornerRadius": 999,
      "priority": 7
    },
    "SWITCH": {
      "wFixed": 36,
      "hFixed": 20,
      "cornerRadius": 999,
      "layoutSizingHorizontal": "FIXED",
      "layoutSizingVertical": "FIXED",
      "priority": 8,
      "variants": {
        "sm": { "width": 28, "height": 16 },
        "default": { "width": 36, "height": 20 }
      }
    },
    "DEFAULT": {
      "layoutSizingHorizontal": "HUG",
      "layoutSizingVertical": "HUG",
      "priority": 0
    }
  }
}
