{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Heuristic thresholds for shadcn UI",
  "heuristics": {
    "appearance": {
      "darkLuminanceThreshold": 100,
      "subtleShadowOpacity": "14",
      "defaultShadowColor": "#00000014"
    },
    "text": {
      "paragraphMinLength": 60,
      "longTextThreshold": 100
    },
    "layout": {
      "defaultCardPadding": 24,
      "defaultCardRadius": 12,
      "defaultButtonHeight": 40,
      "containerWidth": 280,
      "smallComponentWidth": 120,
      "wideComponentWidth": 360,
      "emptyHeight": 100
    },
    "scoring": {
      "standardSpacing": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64],
      "standardRadii": [0, 2, 4, 6, 8, 10, 12, 16, 20, 24, 9999]
    }
  }
}
