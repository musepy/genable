{
  "$schema": "https://design-tokens.org/draft-schema",
  "name": "shadcn/ui",
  "version": "1.0.0",
  "description": "shadcn/ui design system token definitions (Tailwind-based)",
  "components": {
    "BUTTON": {
      "sm": {
        "height": 36,
        "paddingH": 12,
        "radius": 6,
        "fontSize": 14
      },
      "default": {
        "height": 40,
        "paddingH": 16,
        "radius": 6,
        "fontSize": 14
      },
      "lg": {
        "height": 44,
        "paddingH": 24,
        "radius": 8,
        "fontSize": 16
      },
      "icon": {
        "height": 40,
        "width": 40,
        "radius": 6
      }
    },
    "ICON_BUTTON": {
      "sm": {
        "height": 32,
        "width": 32,
        "radius": 6
      },
      "default": {
        "height": 40,
        "width": 40,
        "radius": 6
      },
      "lg": {
        "height": 44,
        "width": 44,
        "radius": 8
      }
    },
    "TEXT_FIELD": {
      "sm": {
        "height": 32,
        "paddingH": 12,
        "radius": 6
      },
      "default": {
        "height": 40,
        "paddingH": 12,
        "radius": 6
      },
      "lg": {
        "height": 44,
        "paddingH": 16,
        "radius": 8
      }
    },
    "CARD": {
      "default": {
        "radius": 12,
        "padding": 24
      },
      "compact": {
        "radius": 8,
        "padding": 16
      }
    },
    "AVATAR": {
      "sm": {
        "height": 32,
        "width": 32,
        "radius": 16
      },
      "default": {
        "height": 40,
        "width": 40,
        "radius": 20
      },
      "lg": {
        "height": 56,
        "width": 56,
        "radius": 28
      }
    },
    "BADGE": {
      "default": {
        "height": 22,
        "paddingH": 8,
        "radius": 999
      },
      "sm": {
        "height": 18,
        "paddingH": 6,
        "radius": 999
      }
    },
    "DIVIDER": {
      "default": {
        "height": 1
      }
    },
    "SWITCH": {
      "default": {
        "width": 36,
        "height": 20,
        "radius": 999
      },
      "sm": {
        "width": 28,
        "height": 16,
        "radius": 999
      }
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48,
    "2xl": 48,
    "3xl": 64,
    "4xl": 96
  },
  "radius": {
    "none": 0,
    "sm": 4,
    "md": 6,
    "lg": 8,
    "xl": 12,
    "2xl": 16,
    "full": 9999
  },
  "typography": {
    "fontFamily": "Inter",
    "weights": {
      "100": "Thin",
      "200": "Extra Light",
      "300": "Light",
      "400": "Regular",
      "500": "Medium",
      "600": "Semi Bold",
      "700": "Bold",
      "800": "Extra Bold",
      "900": "Black",
      "thin": "Thin",
      "extralight": "Extra Light",
      "extra-light": "Extra Light",
      "light": "Light",
      "regular": "Regular",
      "normal": "Regular",
      "medium": "Medium",
      "semibold": "Semi Bold",
      "semi-bold": "Semi Bold",
      "demibold": "Semi Bold",
      "bold": "Bold",
      "extrabold": "Extra Bold",
      "extra-bold": "Extra Bold",
      "black": "Black",
      "heavy": "Black"
    },
    "supportedStyles": [
      "Thin",
      "Extra Light",
      "Light",
      "Regular",
      "Medium",
      "Semi Bold",
      "Bold",
      "Extra Bold",
      "Black"
    ],
    "preloadStyles": [
      "Regular",
      "Medium",
      "Semi Bold",
      "Bold"
    ],
    "semanticWeights": {
      "H1": "Bold",
      "H2": "Semi Bold",
      "H3": "Semi Bold",
      "HEADING": "Semi Bold",
      "TITLE": "Semi Bold",
      "H4": "Medium",
      "LABEL": "Medium",
      "BODY": "Regular",
      "CAPTION": "Regular",
      "DEFAULT": "Regular"
    },
    "scales": {
      "h1": {
        "fontSize": 36,
        "lineHeight": 40,
        "fontWeight": 800
      },
      "h2": {
        "fontSize": 30,
        "lineHeight": 36,
        "fontWeight": 600
      },
      "h3": {
        "fontSize": 24,
        "lineHeight": 32,
        "fontWeight": 600
      },
      "h4": {
        "fontSize": 20,
        "lineHeight": 28,
        "fontWeight": 600
      },
      "body": {
        "fontSize": 16,
        "lineHeight": 24,
        "fontWeight": 400
      },
      "bodySmall": {
        "fontSize": 14,
        "lineHeight": 20,
        "fontWeight": 400
      },
      "label": {
        "fontSize": 14,
        "lineHeight": 16,
        "fontWeight": 500
      },
      "caption": {
        "fontSize": 12,
        "lineHeight": 16,
        "fontWeight": 400
      }
    }
  },
  "semanticFallbacks": {
    "background": "#ffffff",
    "foreground": "#020817",
    "muted": "#f1f5f9",
    "muted-foreground": "#64748b",
    "card": "#ffffff",
    "card-foreground": "#020817",
    "popover": "#ffffff",
    "popover-foreground": "#020817",
    "primary": "#0f172a",
    "primary-foreground": "#f8fafc",
    "secondary": "#f1f5f9",
    "secondary-foreground": "#0f172a",
    "accent": "#f1f5f9",
    "accent-foreground": "#0f172a",
    "destructive": "#ef4444",
    "destructive-foreground": "#f8fafc",
    "border": "#e2e8f0",
    "input": "#e2e8f0",
    "success": "#22c55e",
    "ring": "#94a3b8"
  },
  "colorRoles": {
    "text.primary": "foreground",
    "text.secondary": "muted-foreground",
    "text.disabled": "muted-foreground",
    "text.inverse": "primary-foreground",
    "surface.default": "background",
    "surface.muted": "muted",
    "surface.card": "card",
    "surface.popover": "popover",
    "action.primary": "primary",
    "action.secondary": "secondary",
    "action.destructive": "destructive",
    "action.accent": "accent",
    "border.default": "border",
    "border.input": "input",
    "brand.primary": "primary",
    "interactive.success": "success",
    "interactive.default": "primary"
  }
}