{
  "type": "FRAME",
  "name": "Developer Panel",
  "props": {
    "layoutMode": "VERTICAL",
    "padding": 16,
    "gap": 16,
    "width": 340,
    "fills": ["bg1"]
  },
  "children": [
    {
      "type": "TEXT",
      "name": "Header",
      "props": {
        "characters": "🛠 Developer Tools",
        "fontSize": 14,
        "fontWeight": "BOLD",
        "fills": ["textPrimary"]
      }
    },
    {
      "type": "FRAME",
      "name": "Sync Actions",
      "props": {
        "layoutMode": "HORIZONTAL",
        "gap": 8,
        "layoutAlign": "STRETCH"
      },
      "children": [
        {
          "type": "FRAME",
          "name": "Push",
          "props": {
            "layoutGrow": 1,
            "padding": 8,
            "cornerRadius": 6,
            "fills": ["accent"],
            "primaryAxisAlignItems": "CENTER"
          },
          "children": [{ "type": "TEXT", "name": "L", "props": { "characters": "Push Tokens", "fills": ["#fff"], "fontSize": 11, "fontWeight": "BOLD" } }]
        },
        {
          "type": "FRAME",
          "name": "Pull",
          "props": {
            "layoutGrow": 1,
            "padding": 8,
            "cornerRadius": 6,
            "fills": ["bg2"],
            "strokes": ["accentBorder"],
            "strokeWeight": 1,
            "primaryAxisAlignItems": "CENTER"
          },
          "children": [{ "type": "TEXT", "name": "L", "props": { "characters": "Pull Tokens", "fills": ["accent"], "fontSize": 11, "fontWeight": "BOLD" } }]
        }
      ]
    },
    {
      "type": "FRAME",
      "name": "Library Section",
      "props": {
        "layoutMode": "VERTICAL",
        "gap": 10,
        "layoutAlign": "STRETCH"
      },
      "children": [
        { "type": "TEXT", "name": "Label", "props": { "characters": "PROJECT UI LIBRARY", "fontSize": 10, "fontWeight": "BOLD", "fills": ["textSecondary"] } },
        {
          "type": "FRAME",
          "name": "Item",
          "props": {
            "padding": 12,
            "cornerRadius": 8,
            "fills": ["bg2"],
            "strokes": ["border"],
            "strokeWeight": 1,
            "layoutAlign": "STRETCH"
          },
          "children": [
            { "type": "TEXT", "name": "N", "props": { "characters": "Header (顶部工具栏)", "fontSize": 12, "fontWeight": "BOLD", "fills": ["textPrimary"] } },
            { "type": "TEXT", "name": "P", "props": { "characters": "src/ui/components/Header.tsx", "fontSize": 10, "fills": ["textSecondary"] } }
          ]
        }
      ]
    }
  ]
}
