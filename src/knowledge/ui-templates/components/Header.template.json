{
  "type": "FRAME",
  "name": "Header",
  "props": {
    "layoutMode": "HORIZONTAL",
    "primaryAxisAlignItems": "CENTER",
    "counterAxisAlignItems": "CENTER",
    "paddingLeft": 12,
    "paddingRight": 12,
    "gap": 12,
    "width": 340,
    "height": 52,
    "fills": ["bg1"],
    "strokes": ["border"],
    "strokeWeight": 0,
    "strokeAlign": "OUTSIDE"
  },
  "children": [
    {
      "type": "FRAME",
      "name": "New Design Button",
      "props": {
        "layoutMode": "HORIZONTAL",
        "primaryAxisAlignItems": "CENTER",
        "counterAxisAlignItems": "CENTER",
        "paddingLeft": 10,
        "paddingRight": 10,
        "paddingTop": 4,
        "paddingBottom": 4,
        "gap": 6,
        "cornerRadius": 999,
        "fills": ["bg2"],
        "strokes": ["border"],
        "strokeWeight": 1
      },
      "children": [
        {
          "type": "ICON",
          "name": "Plus Icon",
          "props": {
            "iconName": "lucide:plus",
            "width": 14,
            "height": 14,
            "fills": ["textPrimary"]
          }
        },
        {
          "type": "TEXT",
          "name": "Label",
          "props": {
            "characters": "New Design",
            "fontSize": 12,
            "fontWeight": "MEDIUM",
            "fontFamily": "Inter",
            "fills": ["textPrimary"]
          }
        }
      ]
    },
    {
      "type": "FRAME",
      "name": "Spacer",
      "props": {
        "layoutGrow": 1,
        "layoutMode": "HORIZONTAL",
        "primaryAxisAlignItems": "MIN",
        "counterAxisAlignItems": "CENTER"
      },
      "children": [
        {
          "type": "FRAME",
          "name": "Dogfood Badge",
          "props": {
            "layoutMode": "HORIZONTAL",
            "paddingLeft": 6,
            "paddingRight": 6,
            "paddingTop": 2,
            "paddingBottom": 2,
            "cornerRadius": 4,
            "fills": ["accentMuted"],
            "strokes": ["accentBorder"],
            "strokeWeight": 1
          },
          "children": [
            {
              "type": "TEXT",
              "name": "Badge text",
              "props": {
                "characters": "🧪 DOGFOOD",
                "fontSize": 10,
                "fontWeight": "BOLD",
                "fontFamily": "Inter",
                "fills": ["accent"]
              }
            }
          ]
        }
      ]
    },
    {
      "type": "ICON",
      "name": "Settings",
      "props": {
        "iconName": "lucide:settings",
        "width": 18,
        "height": 18,
        "fills": ["textSecondary"]
