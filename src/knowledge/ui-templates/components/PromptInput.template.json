{
  "type": "FRAME",
  "name": "Prompt Area",
  "props": {
    "layoutMode": "VERTICAL",
    "padding": "12 16",
    "gap": 8,
    "width": 340,
    "fills": ["bg1"]
  },
  "children": [
    {
      "type": "FRAME",
      "name": "Input Container",
      "props": {
        "layoutMode": "HORIZONTAL",
        "primaryAxisAlignItems": "CENTER",
        "counterAxisAlignItems": "CENTER",
        "padding": "8 12",
        "gap": 8,
        "cornerRadius": 20,
        "fills": ["bg2"],
        "strokes": ["border"],
        "strokeWeight": 1,
        "layoutAlign": "STRETCH"
      },
      "children": [
        {
          "type": "ICON",
          "name": "Model Icon",
          "props": {
            "iconName": "lucide:sparkles",
            "width": 14,
            "height": 14,
            "fills": ["accent"]
          }
        },
        {
          "type": "TEXT",
          "name": "Placeholder",
          "props": {
            "characters": "Ask me to design anything...",
            "fontSize": 12,
            "fills": ["textSecondary"],
            "layoutGrow": 1
          }
        },
        {
          "type": "FRAME",
          "name": "Send Button",
          "props": {
            "width": 24,
            "height": 24,
            "cornerRadius": 12,
            "fills": ["solid"],
            "primaryAxisAlignItems": "CENTER",
            "counterAxisAlignItems": "CENTER"
          },
          "children": [
            {
              "type": "ICON",
              "name": "Arrow Up",
              "props": {
                "iconName": "lucide:arrow-up",
                "width": 12,
                "height": 12,
                "fills": ["solidForeground"]
              }
            }
          ]
        }
      ]
    }
  ]
}
