{
  "name": "genable-mcp",
  "version": "0.1.0",
  "description": "Write-side MCP server for Figma — build, edit, restructure, and search Figma designs from Claude Code, Cursor, Cline, or any MCP client. Complements Figma's official MCP (which is read-only). 41 tools covering tree creation (JSX), variables/tokens, components, cross-page navigation, and visual verification.",
  "author": "musec <muse40007@gmail.com>",
  "bugs": {
    "url": "https://github.com/muse40007/figma-ai-generator-dogfood/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "genable-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "extract-schema": "tsx extract-schema.ts",
    "build": "npm run extract-schema && tsc && node -e \"require('fs').copyFileSync('tools-schema.json','dist/tools-schema.json')\"",
    "dev": "npm run extract-schema && tsx index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "figma",
    "figma-mcp",
    "figma-plugin",
    "figma-api",
    "figma-write",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "ai-agent",
    "llm",
    "claude",
    "claude-code",
    "claude-desktop",
    "cursor",
    "cline",
    "design-system",
    "design-tokens",
    "design-automation",
    "ui-generation",
    "generative-ui",
    "jsx",
    "anthropic",
    "genable"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.0.0",
    "typescript": ">=5"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/muse40007/figma-ai-generator-dogfood#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muse40007/figma-ai-generator-dogfood.git",
    "directory": "tools/mcp-server"
  },
  "license": "MIT"
}
